pipeline {
  agent any
  environment {
    ECR_REPOSITORY = credentials('ECR_REPOSITORY')
    AWS_ACCOUNT_ID = credentials('AWS_ACCOUNT_ID')
    AWS_ACCESS_KEY_ID = credentials('AWS_ACCESS_KEY_ID')
    AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
  }

  stages {
    stage("Continuous Integration"){
        steps {
            script {
                echo "Linting repository"
                echo "unit test"
                // sh "python3 tests/test_model.py"
            }
        }
    }
    stage("Login to ECR"){
    steps {
        sh '''
            export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
            export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY
            export AWS_DEFAULT_REGION=eu-north-1

            echo "Checking AWS identity..."
            aws sts get-caller-identity

            echo "Getting ECR login token..."
            aws ecr get-login-password --region eu-north-1 > /tmp/token

            cat /tmp/token | docker login --username AWS --password-stdin $AWS_ACCOUNT_ID.dkr.ecr.eu-north-1.amazonaws.com
        '''
    }
}
    
    stage("Build Image"){
        steps {
            script {
                sh "docker build -t ${AWS_ACCOUNT_ID}.dkr.ecr.eu-north-1.amazonaws.com/${ECR_REPOSITORY}:latest ."
            }
        }
    }
    stage("Push Image to ECR"){
        steps {
            script {
                sh "docker push ${AWS_ACCOUNT_ID}.dkr.ecr.eu-north-1.amazonaws.com/${ECR_REPOSITORY}:latest"
            }
        }
    }
    stage("Continuous Deployment"){
        steps {
            sshagent(['ssh_key']) {
                sh """
                    ssh -o StrictHostKeyChecking=no -l ubuntu 13.62.166.49 '
                        aws ecr get-login-password --region eu-north-1 | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.eu-north-1.amazonaws.com &&
                        docker pull ${AWS_ACCOUNT_ID}.dkr.ecr.eu-north-1.amazonaws.com/${ECR_REPOSITORY}:latest &&
                        docker stop app || true &&
                        docker rm app || true &&
                        docker run -d --name app -p 5001:5001 ${AWS_ACCOUNT_ID}.dkr.ecr.eu-north-1.amazonaws.com/${ECR_REPOSITORY}:latest
                    '
                """
            }
        }
    }
  }

  post {
    always {
      sh 'docker system prune -f'
    }
  }
}









